# Copy to .env and adjust as needed. Used for local runs and (later) deployment.
DB_URL=jdbc:postgresql://localhost:5432/eventrelay
DB_USERNAME=eventrelay
DB_PASSWORD=eventrelay

REDIS_HOST=localhost
REDIS_PORT=6379

# Milestone 2+: SQS. Locally points at LocalStack.
AWS_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_NAME=eventrelay-deliveries
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
