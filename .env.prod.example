# Copy to .env on the droplet and fill in. NEVER commit the real .env.
DB_NAME=eventrelay
DB_USERNAME=eventrelay
DB_PASSWORD=change-me-to-a-long-random-string

# Real AWS SQS (free tier: 1M requests/month, permanently).
# Use an IAM user scoped to just this queue - see docs/DEPLOYMENT.md.
AWS_REGION=us-east-1
SQS_QUEUE_NAME=eventrelay-deliveries
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
